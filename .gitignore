.pio/
.pioenvs/
.piolibdeps/

# ===========================================
# VSCode
# ===========================================
.vscode/
!.vscode/extensions.json   # keep this if you want to share recommended extensions

# ===========================================
# Build output
# ===========================================
build/
*.elf
*.hex
*.bin
*.map

# ===========================================
# OS generated files
# ===========================================

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# ===========================================
# Logs & temp files
# ===========================================
*.log
*.tmp
*.temp
*.swp
*.swo

# ===========================================
# Compiled Python (sometimes used in scripts)
# ===========================================
__pycache__/
*.py[cod]
*.pyo

# ===========================================
# Sensitive / environment files
# ===========================================
.env
.env.*
secrets.h
credentials.h
config_private.h

# ===========================================
# Library manager (dependencies are declared
# in platformio.ini — no need to commit them)
# ===========================================
.lib_deps/
lib_deps/